% neurips_2025.sty - Style file for NeurIPS 2025 (anonymous submission)
% Based on the standard NeurIPS template

\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{neurips_2025}[2025/01/01 NeurIPS 2025 submission]

\RequirePackage{geometry}
\geometry{
  textheight=9in,
  textwidth=5.5in,
  top=1in,
  headheight=12pt,
  headsep=25pt,
  footskip=30pt
}

\RequirePackage{fancyhdr}
\pagestyle{fancy}
\fancyhf{}
\fancyfoot[C]{\thepage}
\renewcommand{\headrulewidth}{0pt}

% Font settings
\renewcommand{\rmdefault}{ptm}

% Title formatting
\renewcommand{\maketitle}{%
  \begin{center}%
    {\LARGE\bfseries \@title \par}%
    \vskip 1.5em%
    {\large \@author \par}%
    \vskip 1em%
    {\large \@date \par}%
  \end{center}%
  \par
  \vskip 1.5em%
}

% Abstract environment
\renewenvironment{abstract}%
{\centerline{\large\bfseries Abstract}\vspace{0.5ex}\begin{quote}}%
{\par\end{quote}\vskip 1ex}

% Section formatting
\RequirePackage{titlesec}
\titleformat{\section}{\large\bfseries}{\thesection}{1em}{}
\titleformat{\subsection}{\normalsize\bfseries}{\thesubsection}{1em}{}
\titleformat{\subsubsection}{\normalsize\itshape}{\thesubsubsection}{1em}{}

% Line spacing
\linespread{1.0}
\setlength{\parskip}{0.5ex plus 0.1ex minus 0.1ex}
\setlength{\parindent}{1.5em}

\endinput
